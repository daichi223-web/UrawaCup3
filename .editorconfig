# EditorConfig - https://editorconfig.org
# Enforce UTF-8 encoding to prevent text corruption and mojibake.

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.py]
indent_size = 4

[*.{ts,tsx,js,jsx}]
indent_size = 2

[*.json]
indent_size = 2

[*.{yaml,yml}]
indent_size = 2
